# Anthropic
ANTHROPIC_API_KEY=

# Reddit (get from https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=FluxIdeas/1.0 by /u/your_reddit_username

# Tavily (get from https://tavily.com)
TAVILY_API_KEY=

# Cloudinary (get from https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Internal security — must match Node.js backend INTERNAL_API_KEY
INTERNAL_API_KEY=

# Node.js backend WebSocket log endpoint
NODEJS_BACKEND_LOG_ENDPOINT_URL=http://localhost:3000/internal/agent-log
