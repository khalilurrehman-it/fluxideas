{
  "name": "FluxIdeas",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:web": "pnpm --filter @FluxIdeas/web dev",
    "dev:server": "pnpm --filter @FluxIdeas/server dev",
    "build": "pnpm -r build",
    "type-check": "pnpm -r type-check"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.33.2",
